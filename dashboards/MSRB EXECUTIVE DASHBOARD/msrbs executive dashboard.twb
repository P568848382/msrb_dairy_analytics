              <calculation class='tableau' formula='IF SUM([total_actual (vw_production_monthly.csv1)])/&#13;&#10;SUM([total_planned (vw_production_monthly.csv1)])*100 &gt;=95&#13;&#10;THEN &quot;On Target&quot;&#13;&#10;ELSEIF SUM([total_actual (vw_production_monthly.csv1)])/&#13;&#10;SUM([total_planned (vw_production_monthly.csv1)])*100 &gt;=90&#13;&#10;THEN &quot;Near Target&quot;&#13;&#10;ELSE &quot;Below Target&quot;&#13;&#10;END' />
            </column>
            <column caption='Category' datatype='string' name='[category]' role='dimension' type='nominal' />
