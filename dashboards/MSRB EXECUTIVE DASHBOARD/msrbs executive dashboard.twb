            <column caption='[MoM Arrow Display]' datatype='string' name='[Calculation_35229510372024322]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF LOOKUP(SUM([mom_growth_pct]),LAST())&gt;=0&#13;&#10;THEN &quot;▲ &quot; +STR(ROUND(ABS(LOOKUP(SUM([mom_growth_pct]),LAST())),1)) + &quot;%&quot;&#13;&#10;ELSE &quot;▼ &quot; + STR(ROUND(ABS(LOOKUP(SUM([mom_growth_pct]), LAST())), 1)) + &quot;%&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='[Date Link]' datatype='date' name='[Calculation_35229510376161283]' role='dimension' type='ordinal'>
