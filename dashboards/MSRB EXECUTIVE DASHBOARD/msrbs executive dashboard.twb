        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontsize='16'>REVENUE BY CATEGORY</run>
            <run fontalignment='1'>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='vw_sales_monthly+' name='federated.1fvyk7c0p8ft2u0zxdxf71go456j' />
            <datasource caption='fact_sales' name='federated.1jnqngx1i53kmh1cghlp40a7m3tk' />
          </datasources>
          <datasource-dependencies datasource='federated.1fvyk7c0p8ft2u0zxdxf71go456j'>
            <column caption='[Revenue Share %]' datatype='real' name='[Calculation_35229510710734867]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([federated.1jnqngx1i53kmh1cghlp40a7m3tk].[net_amount])/TOTAL(SUM([federated.1jnqngx1i53kmh1cghlp40a7m3tk].[net_amount]))'>
                <table-calc ordering-type='Rows' />
