      <aliases enabled='yes' />
      <column caption='[MoM Arrow Display]' datatype='string' name='[Calculation_35229510372024322]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF LOOKUP(SUM([mom_growth_pct]),LAST())&gt;=0&#13;&#10;THEN &quot;▲ &quot; +STR(ROUND(ABS(LOOKUP(SUM([mom_growth_pct]),LAST())),1)) + &quot;%&quot;&#13;&#10;ELSE &quot;▼ &quot; + STR(ROUND(ABS(LOOKUP(SUM([mom_growth_pct]), LAST())), 1)) + &quot;%&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='[Date Link]' datatype='date' name='[Calculation_35229510376161283]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE([year],[month],1)' />
      </column>
      <column caption='[Is last Month]' datatype='boolean' name='[Calculation_35229510377689092]' role='measure' type='nominal'>
        <calculation class='tableau' formula='LAST()=0'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='[MoM Color signal]' datatype='string' name='[Calculation_35229510380195845]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF LOOKUP(SUM([mom_growth_pct]),LAST()) &lt;= 0 THEN &quot;Positive&quot; ELSE &quot;Negative&quot; END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='[Prod Efficiency %]' datatype='real' name='[Calculation_35229510384967687]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_actual (vw_production_monthly.csv1)])/SUM([total_planned (vw_production_monthly.csv1)])' />
      </column>
      <column caption='[Prod Eff Status]' datatype='string' name='[Calculation_35229510386319369]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_actual (vw_production_monthly.csv1)])/&#13;&#10;SUM([total_planned (vw_production_monthly.csv1)])*100 &gt;=95&#13;&#10;THEN &quot;On Target&quot;&#13;&#10;ELSEIF SUM([total_actual (vw_production_monthly.csv1)])/&#13;&#10;SUM([total_planned (vw_production_monthly.csv1)])*100 &gt;=90&#13;&#10;THEN &quot;Near Target&quot;&#13;&#10;ELSE &quot;Below Target&quot;&#13;&#10;END' />
      </column>
      <column caption='[Overall Stockout Rate %]' datatype='real' name='[Calculation_35229510388862986]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([stockout_days (vw_stockout_frequency.csv1)])/SUM([total_days (vw_stockout_frequency.csv1)])' />
      </column>
      <column caption='[Collection Eff %]' datatype='real' name='[Calculation_35229510393274379]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_collected])/SUM([total_billed])' />
      </column>
      <column caption='[Collection Status]' datatype='string' name='[Calculation_35229510394134540]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_collected])/SUM([total_billed])*100 &gt;= 90&#13;&#10;THEN &quot;On Target&quot;&#13;&#10;ELSE &quot;Below Target&quot;&#13;&#10;END' />
      </column>
      <column caption='[Month Sort Order]' datatype='integer' name='[Calculation_35229510681514000]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='[year (vw_sales_monthly.csv)]*100 + [month (vw_sales_monthly.csv)]' />
      </column>
      <column caption='[Month Year Label]' datatype='string' name='[Calculation_35229510683320337]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([month_name (vw_sales_monthly.csv)],3) + &quot; &quot; +STR([year (vw_sales_monthly.csv)])' />
      </column>
      <column caption='[MoM Growth Display]' datatype='real' name='[Calculation_35229510686556178]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [financial_year (vw_sales_monthly.csv)]=&quot;FY2024-25&quot;&#13;&#10;THEN [mom_growth_pct]&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='[Revenue Share %]' datatype='real' name='[Calculation_35229510710734867]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([federated.1jnqngx1i53kmh1cghlp40a7m3tk].[net_amount])/TOTAL(SUM([federated.1jnqngx1i53kmh1cghlp40a7m3tk].[net_amount]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='[Eff Pct Calc]' datatype='real' name='[Calculation_35229510720774164]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_actual (vw_production_monthly.csv1)])/SUM([total_planned (vw_production_monthly.csv1)])' />
      </column>
      <column caption='[Eff Color]' datatype='string' name='[Calculation_35229510723559445]' role='measure' type='nominal'>
        <calculation class='tableau' formula='if SUM([total_actual (vw_production_monthly.csv1)])/SUM([total_planned (vw_production_monthly.csv1)])*100 &gt;= 93.5&#13;&#10;THEN &quot;On Target&quot;&#13;&#10;ELSE &quot;Below Target&quot;&#13;&#10;END' />
      </column>
      <column caption='[Stockout Risk Level]' datatype='string' name='[Calculation_35229510727458838]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [stockout_days (vw_stockout_frequency.csv1)] &gt;= 5 THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [stockout_days (vw_stockout_frequency.csv1)] &gt;=2 THEN &quot;Medium Risk&quot;&#13;&#10;ELSEIF [stockout_days (vw_stockout_frequency.csv1)] &gt;=1 THEN &quot;Low Risk&quot;&#13;&#10;ELSE &quot;No Stockout&quot;&#13;&#10;END' />
      </column>
