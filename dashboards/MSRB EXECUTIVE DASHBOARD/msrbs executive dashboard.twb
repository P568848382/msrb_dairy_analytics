              <calculation class='tableau' formula='SUM([total_actual (vw_production_monthly.csv1)])/SUM([total_planned (vw_production_monthly.csv1)])' />
            </column>
            <column caption='[Eff Color]' datatype='string' name='[Calculation_35229510723559445]' role='measure' type='nominal'>
              <calculation class='tableau' formula='if SUM([total_actual (vw_production_monthly.csv1)])/SUM([total_planned (vw_production_monthly.csv1)])*100 &gt;= 93.5&#13;&#10;THEN &quot;On Target&quot;&#13;&#10;ELSE &quot;Below Target&quot;&#13;&#10;END' />
