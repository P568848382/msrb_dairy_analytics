          <datasource-dependencies datasource='federated.0ouizpl0a2kkft13ja6bx17uiyej'>
            <column caption='Avg Invoice Value' datatype='real' name='[Calculation_24416912679907338]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([net_amount])/COUNTD([invoice_number])' />
            </column>
            <column-instance column='[customer_segment]' derivation='Attribute' name='[attr:customer_segment:nk]' pivot='key' type='nominal' />
            <column caption='Customer Segment' datatype='string' name='[customer_segment]' role='dimension' type='nominal' />
