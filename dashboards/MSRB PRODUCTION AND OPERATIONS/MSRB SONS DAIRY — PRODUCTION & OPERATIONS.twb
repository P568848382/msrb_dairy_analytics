      <column caption='[Category Eff Status]' datatype='string' name='[Calculation_0261193014079488]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([efficiency_pct (vw_category_efficiency.csv)])&gt;=95 THEN &quot;On Target&quot;&#13;&#10;ELSEIF AVG([efficiency_pct (vw_category_efficiency.csv)])&gt;=90 THEN &quot;Near Target&quot;&#13;&#10;ELSE &quot;Below Target&quot;&#13;&#10;END' />
      </column>
      <column caption='[Band Pct]' datatype='real' name='[Calculation_0261193196384261]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([production_id])/TOTAL(COUNTD([production_id]))*100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Production Runs' datatype='integer' name='[Calculation_0261193199230983]' role='measure' type='quantitative'>
