      <table>
        <view>
          <datasources>
            <datasource caption='fact_production+' name='federated.190ffku0pro99i19xkxa60h9g9k2' />
          </datasources>
          <datasource-dependencies datasource='federated.190ffku0pro99i19xkxa60h9g9k2'>
            <column caption='AVG(0)' datatype='real' name='[Calculation_0261193194926082]' role='measure' type='quantitative' user:unnamed='Efficiency_Band_Donut'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='AVG(0)' datatype='real' name='[Calculation_0261193194967044]' role='measure' type='quantitative' user:unnamed='Efficiency_Band_Donut'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='[Band Pct]' datatype='real' name='[Calculation_0261193196384261]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([production_id])/TOTAL(COUNTD([production_id]))*100'>
                <table-calc ordering-type='Rows' />
              </calculation>
