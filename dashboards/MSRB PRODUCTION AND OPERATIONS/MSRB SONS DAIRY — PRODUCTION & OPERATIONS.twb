      </column>
      <column caption='[Shift Diff Note]' datatype='string' name='[Calculation_0261193210724360]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Evening Production Share leads by 2.74%&quot;' />
      </column>
      <column caption='[Prod Eff %]' datatype='real' name='[Calculation_52362101131374593]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_actual])/SUM([total_planned])*100' />
      </column>
      <column caption='[Eff Status]' datatype='string' name='[Calculation_52362101138673666]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_actual])/SUM([total_planned])*100&gt;=95&#13;&#10;THEN  &quot;On Target&quot;&#13;&#10;ELSEIF SUM([total_actual])/SUM([total_planned])*100 &gt;=90&#13;&#10;THEN &quot;Near Target&quot;&#13;&#10;ELSE&#13;&#10;&quot;Below Target&quot;&#13;&#10;END' />
      </column>
      <column caption='[Eff KPI Label]' datatype='string' name='[Calculation_52362101139959811]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Production Efficiency&quot;' />
      </column>
      <column caption='[Wastage Rate %]' datatype='real' name='[Calculation_52362101140750340]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_wastage])/SUM([total_actual])*100' />
      </column>
      <column caption='[Wastage Status]' datatype='string' name='[Calculation_52362101141889029]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_wastage])/SUM([total_actual])*100&lt;=1&#13;&#10;THEN &quot;Excellent&quot;&#13;&#10;ELSEIF SUM([total_wastage])/SUM([total_actual])*100&lt;=3&#13;&#10;THEN &quot;Acceptble&quot;&#13;&#10;ELSE&#13;&#10;&quot;High Wastage&quot;&#13;&#10;END' />
      </column>
      <column caption='Wastage Label' datatype='string' name='[Calculation_52362101142622214]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Wastage Rate (Target &lt;3%)&quot;' />
      </column>
      <column caption='[Efficiency Gap]' datatype='real' name='[Calculation_52362101145731079]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([total_actual])/SUM([total_planned])*100)-95' />
      </column>
      <column caption='[Gap Display]' datatype='string' name='[Calculation_52362101146767368]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF (SUM([total_actual])/SUM([total_planned])*100) - 95 &gt;= 0&#13;&#10;THEN &quot;▲ +&quot; + STR(ROUND((SUM([total_actual])/SUM([total_planned])*100)-95, 2)) + &quot;%&quot;&#13;&#10;ELSE &quot;▼ &quot; + STR(ROUND((SUM([total_actual])/SUM([total_planned])*100)-95, 2)) + &quot;%&quot;&#13;&#10;END' />
      </column>
      <column caption='[Gap Status]' datatype='string' name='[Calculation_52362101148389385]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF (SUM([total_actual])/SUM([total_planned])*100) - 95 &gt;= 0&#13;&#10;THEN &quot;Above Target&quot;&#13;&#10;ELSE &quot;Below Target&quot;&#13;&#10;END' />
      </column>
      <column caption='[YIELD %]' datatype='real' name='[Calculation_52362101150625802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_produced_qty])/SUM([raw_milk_used_l])*100' />
      </column>
      <column caption='YIELD STATUS' datatype='string' name='[Calculation_52362101151236107]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([net_produced_qty])/SUM([raw_milk_used_l])*100 &gt;=50&#13;&#10;THEN &quot;Good&quot;&#13;&#10;ELSEIF SUM([net_produced_qty])/SUM([raw_milk_used_l])*100 &gt;=40&#13;&#10;THEN &quot;Average&quot;&#13;&#10;ELSE &quot;Poor&quot;&#13;&#10;END' />
      </column>
      <column caption='[Period Label]' datatype='string' name='[Calculation_52362101215604749]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([month_name (vw_production_monthly.csv)],3) +&quot; &quot; +STR([year (vw_production_monthly.csv)])' />
