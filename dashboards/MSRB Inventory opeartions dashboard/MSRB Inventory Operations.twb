            <column caption='[Stockout Risk Level]' datatype='string' name='[Calculation_7655959187779594]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [stockout_days] &gt;= 5   THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [stockout_days] &gt;= 2 THEN &quot;Medium Risk&quot;&#13;&#10;ELSEIF [stockout_days] &gt;= 1 THEN &quot;Low Risk&quot;&#13;&#10;ELSE                           &quot;No Stockout&quot;&#13;&#10;END' />
            </column>
            <column caption='[Stockout Label]' datatype='string' name='[Calculation_7655959190347787]' role='measure' type='nominal'>
              <calculation class='tableau' formula='STR(ROUND(AVG([stockout_rate_pct]),2)) + &quot;% (&quot; + &#13;&#10;STR(SUM([stockout_days])) + &quot; days)&quot;' />
            </column>
            <column-instance column='[critical_days]' derivation='Avg' name='[avg:critical_days:qk]' pivot='key' type='quantitative' />
