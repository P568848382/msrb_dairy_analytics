    <worksheet name='Stockout_Frequency_Bar'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontname='Tableau Book'>PRODUCT STOCKOUT FREQUENCY(HISTORICAL- 626 DAYS)</run>
            <run fontalignment='1'>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_inventory' name='federated.1enhqh404tx0p6142zg250d1vv6e' />
