    <worksheet name='Inv_Stockout_Rate_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontname='Tableau Book'>STOCKOUT RATE %</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_inventory' name='federated.1enhqh404tx0p6142zg250d1vv6e' />
          </datasources>
          <datasource-dependencies datasource='federated.1enhqh404tx0p6142zg250d1vv6e'>
            <column caption=' [Stockout Rate %]' datatype='real' name='[Calculation_7655959091015682]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [stock_status]=&quot;Stockout&quot; THEN 1 ELSE 0 END)&#13;&#10;/COUNT([inventory_id])*100' />
            </column>
            <column caption='[Stockout Status]' datatype='string' name='[Calculation_7655959091838979]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF  SUM(IF [stock_status]=&quot;Stockout&quot; THEN 1 ELSE 0 END)&#13;&#10;/COUNT([inventory_id])*100=0&#13;&#10;THEN &quot;Perfect&quot;&#13;&#10;ELSEIF SUM(IF [stock_status]=&quot;Stockout&quot; THEN 1 ELSE 0 END)&#13;&#10;/COUNT([inventory_id])*100&lt;=1&#13;&#10;THEN &quot;Acceptable&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
            </column>
            <column caption='Inventory Id' datatype='string' name='[inventory_id]' role='dimension' type='nominal' />
            <column caption='Stock Status' datatype='string' name='[stock_status]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_7655959091015682]' derivation='User' name='[usr:Calculation_7655959091015682:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_7655959091838979]' derivation='User' name='[usr:Calculation_7655959091838979:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.1enhqh404tx0p6142zg250d1vv6e].[usr:Calculation_7655959091015682:qk]' value='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#2d3748' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <color column='[federated.1enhqh404tx0p6142zg250d1vv6e].[usr:Calculation_7655959091838979:nk]' />
              <text column='[federated.1enhqh404tx0p6142zg250d1vv6e].[usr:Calculation_7655959091015682:qk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run fontcolor='#000000' fontname='Benton Sans Book'><![CDATA[Stockout Rate (Target: 0%):<[federated.1enhqh404tx0p6142zg250d1vv6e].[usr:Calculation_7655959091015682:qk]>]]></run>
                <run fontcolor='#757575'>Æ&#9;</run>
              </formatted-text>
            </customized-tooltip>
