    <worksheet name='Inv_At_Risk_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontname='Tableau Book'>PRODUCTS AVG SHELF LIFE </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_inventory' name='federated.1enhqh404tx0p6142zg250d1vv6e' />
          </datasources>
          <datasource-dependencies datasource='federated.1enhqh404tx0p6142zg250d1vv6e'>
            <column caption='[Shelf life status]' datatype='string' name='[Calculation_7655959098429444]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([shelf_life_days (vw_stock_supply_risk.csv)])&lt;=7 THEN &quot;No Risk&quot;&#13;&#10;ELSEIF AVG([shelf_life_days (vw_stock_supply_risk.csv)])&lt;=10 THEN &quot;Moderate Risk&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
            </column>
            <column-instance column='[shelf_life_days]' derivation='Avg' name='[avg:shelf_life_days:qk]' pivot='key' type='quantitative' />
            <column-instance column='[supply_risk]' derivation='None' name='[none:supply_risk:nk]' pivot='key' type='nominal' />
            <column caption='Shelf Life Days (Vw Stock Supply Risk.Csv)' datatype='integer' name='[shelf_life_days (vw_stock_supply_risk.csv)]' role='measure' type='quantitative' />
