      <aliases enabled='yes' />
      <column caption='Is Latest Date' datatype='boolean' name='[Calculation_7655959089049600]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[date]={FIXED :MAX([date])}' />
      </column>
      <column caption=' [Stockout Rate %]' datatype='real' name='[Calculation_7655959091015682]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [stock_status]=&quot;Stockout&quot; THEN 1 ELSE 0 END)&#13;&#10;/COUNT([inventory_id])*100' />
      </column>
      <column caption='[Stockout Status]' datatype='string' name='[Calculation_7655959091838979]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF  SUM(IF [stock_status]=&quot;Stockout&quot; THEN 1 ELSE 0 END)&#13;&#10;/COUNT([inventory_id])*100=0&#13;&#10;THEN &quot;Perfect&quot;&#13;&#10;ELSEIF SUM(IF [stock_status]=&quot;Stockout&quot; THEN 1 ELSE 0 END)&#13;&#10;/COUNT([inventory_id])*100&lt;=1&#13;&#10;THEN &quot;Acceptable&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='[Shelf life status]' datatype='string' name='[Calculation_7655959098429444]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([shelf_life_days (vw_stock_supply_risk.csv)])&lt;=7 THEN &quot;No Risk&quot;&#13;&#10;ELSEIF AVG([shelf_life_days (vw_stock_supply_risk.csv)])&lt;=10 THEN &quot;Moderate Risk&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='[Turnover Status]' datatype='string' name='[Calculation_7655959101104133]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([turnover_ratio])&gt;=5 THEN &quot;Healthy&quot;&#13;&#10;ELSEIF AVG([turnover_ratio])&gt;=1 THEN &quot;Watch&quot;&#13;&#10;ELSE &quot;Dead Stock Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Current_Stock_Highlight' datatype='boolean' name='[Calculation_7655959169937414]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[date]={ FIXED : MAX([date]) }' />
      </column>
      <column caption='[Risk Icon]' datatype='string' name='[Calculation_7655959171588103]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [shelf_life_risk] = &quot;At Risk&quot; THEN &quot;⚠ At Risk&quot;&#13;&#10;ELSE &quot;✓ Safe&quot;&#13;&#10;END' />
      </column>
      <column caption='[Reorder Alert]' datatype='string' name='[Calculation_7655959171969032]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([closing_stock]) &lt;= AVG([reorder_level])&#13;&#10;THEN &quot;⚡ REORDER&quot;&#13;&#10;ELSE &quot;&quot;&#13;&#10;END' />
      </column>
      <column caption='last date' datatype='date' name='[Calculation_7655959176671241]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='MAX([date])' />
      </column>
      <column caption='[Stockout Risk Level]' datatype='string' name='[Calculation_7655959187779594]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [stockout_days] &gt;= 5   THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [stockout_days] &gt;= 2 THEN &quot;Medium Risk&quot;&#13;&#10;ELSEIF [stockout_days] &gt;= 1 THEN &quot;Low Risk&quot;&#13;&#10;ELSE                           &quot;No Stockout&quot;&#13;&#10;END' />
      </column>
      <column caption='[Stockout Label]' datatype='string' name='[Calculation_7655959190347787]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(AVG([stockout_rate_pct]),2)) + &quot;% (&quot; + &#13;&#10;STR(SUM([stockout_days])) + &quot; days)&quot;' />
      </column>
      <column aggregation='Sum' caption='[PERIOD SORT]' datatype='integer' name='[Calculation_7655959195172876]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='[year (vw_monthly_turnover.csv1)]*100+[month (vw_monthly_turnover.csv)]' />
      </column>
      <column caption='[PERIOD LABEL]' datatype='string' name='[Calculation_7655959195467789]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([month_name (vw_monthly_turnover.csv)],3) + &quot; &quot; +STR([year (vw_monthly_turnover.csv)])' />
      </column>
      <column caption='FINANCIAL DATE ORDER' datatype='date' name='[Calculation_7655959201038350]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(STR([year (vw_monthly_turnover.csv)])+&quot;-&quot;+STR([month (vw_monthly_turnover.csv)])+&quot;-01&quot;)' />
      </column>
      <column caption='[Shelf Life Line]' datatype='real' name='[Calculation_7655959407697935]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([shelf_life_days (vw_stock_supply_risk.csv)])' />
      </column>
