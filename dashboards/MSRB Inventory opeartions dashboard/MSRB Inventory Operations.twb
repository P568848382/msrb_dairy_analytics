              <formatted-text>
                <run bold='true' fontcolor='#60a5fa' fontsize='28'>&lt;</run>
                <run bold='true' fontcolor='#60a5fa' fontsize='28'>[federated.1enhqh404tx0p6142zg250d1vv6e].[usr:Calculation_7655959091015682:qk]</run>
                <run bold='true' fontcolor='#60a5fa' fontsize='28'>&gt;</run>
              </formatted-text>
            </customized-label>
            <style>
              <style-rule element='cell'>
                <format attr='text-align' value='center' />
                <format attr='vertical-align' value='top' />
              </style-rule>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows />
        <cols />
      </table>
