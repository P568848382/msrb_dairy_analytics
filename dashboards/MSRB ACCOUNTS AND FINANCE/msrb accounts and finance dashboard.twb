    <worksheet name='Billing_Collections_Combo'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontname='Tableau Book'>MONTHLY BILLING vs COLLECTIONS WITH EFFICIENCY TREND</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_accounts+' name='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw' />
