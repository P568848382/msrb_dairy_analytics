  <worksheets>
    <worksheet name='Acc_CollEff_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontname='Tableau Book'>COLLECTION EFFICIENCY %</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_accounts+' name='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw' />
          </datasources>
          <datasource-dependencies datasource='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw'>
            <column caption=' [Overall Collection Eff]' datatype='real' name='[Calculation_15427309135335427]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([total_collected])/SUM([total_billed])*100' />
            </column>
            <column caption='[Coll Eff Status]' datatype='string' name='[Calculation_15427309135908868]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([total_collected])/SUM([total_billed])*100&gt;=90&#13;&#10;THEN &quot;ON TARGET&quot;&#13;&#10;ELSEIF SUM([total_collected])/SUM([total_billed])*100 &gt;=85&#13;&#10;THEN &quot;NEAR TARGET&quot;&#13;&#10;ELSE &quot;BELOW TARGET&quot;&#13;&#10;END' />
            </column>
            <column caption='Customer Type (Vw Customer Payment.Csv)' datatype='string' name='[customer_type (vw_customer_payment.csv)]' role='dimension' type='nominal' />
            <column caption='Financial Year (Vw Billing Collections.Csv)' datatype='string' name='[financial_year (vw_billing_collections.csv)]' role='dimension' type='nominal' />
            <column-instance column='[customer_type (vw_customer_payment.csv)]' derivation='None' name='[none:customer_type (vw_customer_payment.csv):nk]' pivot='key' type='nominal' />
            <column-instance column='[financial_year (vw_billing_collections.csv)]' derivation='None' name='[none:financial_year (vw_billing_collections.csv):nk]' pivot='key' type='nominal' />
            <column-instance column='[payment_status]' derivation='None' name='[none:payment_status:nk]' pivot='key' type='nominal' />
            <column caption='Payment Status' datatype='string' name='[payment_status]' role='dimension' type='nominal' />
            <column caption='Total Billed' datatype='real' name='[total_billed]' role='measure' type='quantitative' />
            <column caption='Total Collected' datatype='real' name='[total_collected]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_15427309135335427]' derivation='User' name='[usr:Calculation_15427309135335427:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_15427309135908868]' derivation='User' name='[usr:Calculation_15427309135908868:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <slices>
            <column>[federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw].[none:financial_year (vw_billing_collections.csv):nk]</column>
            <column>[federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw].[none:customer_type (vw_customer_payment.csv):nk]</column>
            <column>[federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw].[none:payment_status:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw].[usr:Calculation_15427309135335427:qk]' value='n#,##0.0&quot;%&quot;;-#,##0.0&quot;%&quot;' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#2d3748' />
          </style-rule>
        </style>
        <panes>
