    <worksheet name='Aging_Stacked_Bar'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontname='Tableau Book'>RECEIVABLES AGING ANALYSIS - OVERDUE INVOICES ONLY</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_accounts+' name='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw' />
          </datasources>
          <datasource-dependencies datasource='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw'>
            <column caption='[Aging Label]' datatype='string' name='[Calculation_15427309344309258]' role='measure' type='nominal'>
              <calculation class='tableau' formula='&quot;₹&quot; + STR(ROUND(SUM([outstanding_amount])/1000,0)) + &quot;K&quot; + CHAR(10) +&#13;&#10;STR(ROUND(SUM([outstanding_amount])/TOTAL(SUM([outstanding_amount]))*100,1)) + &quot;%&quot;'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Aging Bucket (Vw Receivables Aging.Csv)' datatype='string' name='[aging_bucket (vw_receivables_aging.csv)]' role='dimension' type='nominal' />
            <column caption='Customer Type (Vw Customer Payment.Csv)' datatype='string' name='[customer_type (vw_customer_payment.csv)]' role='dimension' type='nominal' />
            <column caption='Financial Year (Vw Billing Collections.Csv)' datatype='string' name='[financial_year (vw_billing_collections.csv)]' role='dimension' type='nominal' />
            <column-instance column='[aging_bucket (vw_receivables_aging.csv)]' derivation='None' name='[none:aging_bucket (vw_receivables_aging.csv):nk]' pivot='key' type='nominal' />
            <column-instance column='[customer_type (vw_customer_payment.csv)]' derivation='None' name='[none:customer_type (vw_customer_payment.csv):nk]' pivot='key' type='nominal' />
            <column-instance column='[financial_year (vw_billing_collections.csv)]' derivation='None' name='[none:financial_year (vw_billing_collections.csv):nk]' pivot='key' type='nominal' />
            <column-instance column='[payment_status]' derivation='None' name='[none:payment_status:nk]' pivot='key' type='nominal' />
            <column caption='Outstanding Amount' datatype='real' name='[outstanding_amount]' role='measure' type='quantitative' />
            <column caption='Payment Status' datatype='string' name='[payment_status]' role='dimension' type='nominal' />
            <column caption='Sort Order' datatype='integer' name='[sort_order]' role='measure' type='quantitative' />
            <column-instance column='[outstanding_amount]' derivation='Sum' name='[sum:outstanding_amount:qk]' pivot='key' type='quantitative' />
            <column-instance column='[sort_order]' derivation='Sum' name='[sum:sort_order:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_15427309344309258]' derivation='User' name='[usr:Calculation_15427309344309258:nk]' pivot='key' type='nominal'>
              <table-calc ordering-type='Rows' />
