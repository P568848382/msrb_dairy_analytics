    <worksheet name='CustType_Grouped_Bar'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontname='Tableau Book'>COLLECTION EFFICIENCY &amp; PAYMENT SPEED BY CUSTOMER SEGMENT</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_accounts+' name='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw' />
          </datasources>
          <datasource-dependencies datasource='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw'>
            <column caption='[Cust Type Risk]' datatype='string' name='[Calculation_15427309487005713]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([collection_efficiency_pct (vw_custtype_efficiency.csv)])&gt;=90 THEN &quot;Reliable (≥90%)&quot;&#13;&#10;ELSEIF AVG([collection_efficiency_pct (vw_custtype_efficiency.csv)])&gt;=85 THEN &quot;Watch (85-90%)&quot;&#13;&#10;ELSE &quot;High Risk (&lt;85%)&quot;&#13;&#10;END' />
            </column>
            <column caption='[Revenue Share]' datatype='real' name='[Calculation_15427309491474450]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([total_billed (vw_custtype_efficiency.csv)])/TOTAL(SUM([total_billed (vw_custtype_efficiency.csv)]))*100'>
