      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw].[sum:outstanding_amount (vw_customer_payment.csv):qk]&quot;' value='Outstanding Amount' />
          <alias key='&quot;[federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw].[sum:total_billed (vw_customer_payment.csv):qk]&quot;' value='Total Billed' />
        </aliases>
      </column>
      <column caption='[Collected vs Billed Status]' datatype='string' name='[Calculation_15427309129760768]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_collected])/SUM([total_billed])*100 &gt;=90&#13;&#10;THEN &quot;ON TARGET&quot;&#13;&#10;ELSE &quot;BELOW TARGET&quot;&#13;&#10;END' />
      </column>
      <column caption='[Outstanding Alert]' datatype='string' name='[Calculation_15427309131456513]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_outstanding])/SUM([total_billed])*100&lt;=5&#13;&#10;THEN &quot;HEALTHY&quot;&#13;&#10;ELSEIF SUM([total_outstanding])/SUM([total_billed])*100 &lt;=15&#13;&#10;THEN &quot;WATCH&quot;&#13;&#10;ELSE &quot;HIGH RISK&quot;&#13;&#10;END' />
      </column>
      <column caption='[DSO STATUS]' datatype='string' name='[Calculation_15427309133418498]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([dso_days])&lt;=15 THEN &quot;GOOD&quot;&#13;&#10;ELSEIF AVG([dso_days])&lt;=30 THEN &quot;MODERATE&quot;&#13;&#10;ELSE &quot;HIGH&quot;&#13;&#10;END' />
      </column>
      <column caption=' [Overall Collection Eff]' datatype='real' name='[Calculation_15427309135335427]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_collected])/SUM([total_billed])*100' />
      </column>
      <column caption='[Coll Eff Status]' datatype='string' name='[Calculation_15427309135908868]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([total_collected])/SUM([total_billed])*100&gt;=90&#13;&#10;THEN &quot;ON TARGET&quot;&#13;&#10;ELSEIF SUM([total_collected])/SUM([total_billed])*100 &gt;=85&#13;&#10;THEN &quot;NEAR TARGET&quot;&#13;&#10;ELSE &quot;BELOW TARGET&quot;&#13;&#10;END' />
      </column>
      <column caption='[PERIOD SORT]' datatype='integer' name='[Calculation_15427309326082053]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[year (vw_billing_collections.csv)]*100+[month (vw_billing_collections.csv)]' />
      </column>
      <column caption='[PERIOD LABEL]' datatype='string' name='[Calculation_15427309326274566]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([month_name (vw_billing_collections.csv)],3)+STR([year (vw_billing_collections.csv)])' />
      </column>
      <column caption='[Uncollected Amount]' datatype='real' name='[Calculation_15427309333004296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_billed])-SUM([total_collected])' />
      </column>
      <column caption='[Aging Share %]' datatype='real' name='[Calculation_15427309343866889]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([outstanding_amount])/TOTAL(SUM([outstanding_amount]))*100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='[Aging Label]' datatype='string' name='[Calculation_15427309344309258]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;₹&quot; + STR(ROUND(SUM([outstanding_amount])/1000,0)) + &quot;K&quot; + CHAR(10) +&#13;&#10;STR(ROUND(SUM([outstanding_amount])/TOTAL(SUM([outstanding_amount]))*100,1)) + &quot;%&quot;'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='[Payment Risk Level]' datatype='string' name='[Calculation_15427309358882827]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([collection_efficiency_pct (vw_customer_payment.csv)])&gt;=90 THEN &quot;LOW RISK&quot;&#13;&#10;ELSEIF AVG([collection_efficiency_pct (vw_customer_payment.csv)])&gt;=75 THEN &quot;MEDIUM RISK&quot;&#13;&#10;ELSE &quot;HIGH RISK&quot;&#13;&#10;END' />
      </column>
      <column caption='[Alert Icon]' datatype='string' name='[Calculation_15427309394391052]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([collection_efficiency_pct (vw_customer_payment.csv)])&lt;75 then &quot;HIGH RISK&quot;&#13;&#10;ELSEIF AVG([collection_efficiency_pct (vw_customer_payment.csv)])&lt;90 THEN &quot;WATCH&quot;&#13;&#10;ELSE &quot;OK&quot;&#13;&#10;END' />
      </column>
      <column caption='[Period Sort]' datatype='integer' name='[Calculation_15427309456543757]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[year (vw_dso_monthly.csv)]*100+[month (vw_dso_monthly.csv)]' />
      </column>
      <column caption='[PERIOD LABEL_DSO]' datatype='string' name='[Calculation_15427309456756750]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([month_name (vw_dso_monthly.csv)],3) +&quot; &quot;+STR([year (vw_dso_monthly.csv)])' />
      </column>
      <column caption='[DSO Good Zone]' datatype='integer' name='[Calculation_15427309475909647]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='15' />
      </column>
      <column caption='[DSO Warning Zone]' datatype='integer' name='[Calculation_15427309475991568]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='30' />
      </column>
      <column caption='[Cust Type Risk]' datatype='string' name='[Calculation_15427309487005713]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([collection_efficiency_pct (vw_custtype_efficiency.csv)])&gt;=90 THEN &quot;Reliable (≥90%)&quot;&#13;&#10;ELSEIF AVG([collection_efficiency_pct (vw_custtype_efficiency.csv)])&gt;=85 THEN &quot;Watch (85-90%)&quot;&#13;&#10;ELSE &quot;High Risk (&lt;85%)&quot;&#13;&#10;END' />
      </column>
      <column caption='[Revenue Share]' datatype='real' name='[Calculation_15427309491474450]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_billed (vw_custtype_efficiency.csv)])/TOTAL(SUM([total_billed (vw_custtype_efficiency.csv)]))*100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
