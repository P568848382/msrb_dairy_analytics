    <worksheet name='Acc_DSO_KPI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontname='Tableau Book'>DSO DAYS</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_accounts+' name='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw' />
          </datasources>
          <datasource-dependencies datasource='federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw'>
            <column caption='[DSO STATUS]' datatype='string' name='[Calculation_15427309133418498]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([dso_days])&lt;=15 THEN &quot;GOOD&quot;&#13;&#10;ELSEIF AVG([dso_days])&lt;=30 THEN &quot;MODERATE&quot;&#13;&#10;ELSE &quot;HIGH&quot;&#13;&#10;END' />
            </column>
            <column-instance column='[dso_days]' derivation='Avg' name='[avg:dso_days:qk]' pivot='key' type='quantitative' />
