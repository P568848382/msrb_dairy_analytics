              <text column='[federated.0tu6j4t1f6t9cu1gaujsv0wb1kfw].[usr:Calculation_15427309135335427:qk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run fontcolor='#757575'> COLLECTION EFFICIENCY(TARGET 90%):</run>
