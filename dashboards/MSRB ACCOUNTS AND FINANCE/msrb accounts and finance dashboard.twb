              <calculation class='tableau' formula='SUM([total_collected])/SUM([total_billed])*100' />
            </column>
            <column caption='[PERIOD SORT]' datatype='integer' name='[Calculation_15427309326082053]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[year (vw_billing_collections.csv)]*100+[month (vw_billing_collections.csv)]' />
            </column>
            <column caption='[PERIOD LABEL]' datatype='string' name='[Calculation_15427309326274566]' role='dimension' type='nominal'>
